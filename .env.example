# FastAPI Settings
PROJECT_NAME="Caja Chica AI Bot"
ENVIRONMENT=local

# Meta/WhatsApp API
WHATSAPP_API_TOKEN=your_meta_access_token_here
WHATSAPP_VERIFY_TOKEN=your_webhook_verification_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# OpenAI API
OPENAI_API_KEY=your_openai_share_key_here

# Celery & Redis
REDIS_URL=redis://redis:6379/0

# Base de Datos
DATABASE_URL=postgresql://postgres:postgres@db:5432/cajachicadb

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_APPLICATION_CREDENTIALS=/code/credentials.json